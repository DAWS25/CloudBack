{
  "name": "CloudBack DevContainer",
  
  "image": "debian:bookworm",
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "username": "vscode",
      "userUid": "1000",
      "userGid": "1000"
    },
    "ghcr.io/devcontainers/features/docker-in-docker:2.16.0": {},
    "ghcr.io/audacioustux/devcontainers/graalvm:1":{},
    "ghcr.io/devcontainers-community/features/direnv:1":{}
  },
  "postCreateCommand": "./.devcontainer/post-create.sh",

  "forwardPorts": [
    80,
    443,
    10080,
    10443
  ],

  "portsAttributes": {
    "10080": {
      "visibility": "public"
    },
    "10443": {
      "visibility": "public"
    }
  },

  "customizations": {
    "vscode": {
      "extensions": [
          "ms-azuretools.vscode-docker",

          "github.copilot",
          "github.copilot-chat",

          "aws-scripting-guy.cform",

          "ms-python.python",

          "vscjava.vscode-java-pack",
          
          "mkhl.direnv",

          "jetpack-io.devbox"
        
      ]
    }
  },
  "remoteUser": "vscode"
}
